{
  "expo": {
    "name": "zonalvalue.ph",
    "slug": "zonal-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zonalapp",
    "userInterfaceStyle": "automatic",
    "ios": {},
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "package": "com.juliecor.zonalapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 170,
          "android": {
            "backgroundColor": "#244088",
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 170
          }
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Unlock zonalvalue.ph with Face ID."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow zonalvalue.ph to access your photos to set a profile picture.",
          "cameraPermission": "Allow zonalvalue.ph to use the camera to take a profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4920bce6-eba6-455f-b2b6-02b4158f344b"
      }
    }
  }
}
